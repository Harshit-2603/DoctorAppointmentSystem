@using AppointmentSystem.Models.Models
@model AppointmentSystem.Models.Models.ApplicationUser

@{
    ViewData["Title"] = "Create User";
}

<h2>Create New User</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label class="control-label">Full Name</label>
                <input name="FullName" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Email</label>
                <input name="Email" type="email" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Password</label>
                <input name="Password" type="password" class="form-control" required />
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Role</label>
                <select name="Role" class="form-control" asp-items="Html.GetEnumSelectList<UserRole>()">
                </select>
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Specialization (Doctors Only)</label>
                <input name="Specialization" class="form-control" placeholder="e.g. Cardiologist" />
            </div>
            <div class="form-group">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>