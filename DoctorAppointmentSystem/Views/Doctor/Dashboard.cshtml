@using AppointmentSystem.Models.Models
@model List<AppointmentSystem.Models.Models.Appointment>
@{
    ViewData["Title"] = "My Bookings";
}

<h2>My Bookings</h2>

@if (TempData["Info"] != null)
{
    <div class="alert alert-success">@TempData["Info"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">You don't have any booked appointments yet.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Appointment Time</th>
                <th>Patient</th>
                <th>Email</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.AppointmentDateTime.ToString("f")</td>
                    <td>@(item.Patient?.FullName ?? "—")</td>
                    <td>@(item.Patient?.Email ?? "—")</td>
                    <td>
                        <span class="badge @(item.Status switch {
                            AppointmentStatus.Completed => "bg-success",
                            AppointmentStatus.Cancelled => "bg-danger",
                            AppointmentStatus.Confirmed => "bg-primary",
                            _ => "bg-secondary"
                        })">@item.Status</span>
                    </td>
                    <td>
                        @if (item.Status == AppointmentStatus.Confirmed)
                        {
                            <form asp-action="ChangeStatus" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="appointmentId" value="@item.Id" />
                                <input type="hidden" name="newStatus" value="@((int)AppointmentStatus.Completed)" />
                                <button type="submit" class="btn btn-sm btn-success">Mark Completed</button>
                            </form>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
