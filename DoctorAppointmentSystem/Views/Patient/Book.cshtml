@model AppointmentSystem.Models.Models.Appointment

@{
    ViewData["Title"] = "Confirm Booking";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-success">
                <div class="card-header bg-success text-white">
                    <h4>Confirm Your Appointment</h4>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Doctor:</dt>
                        <dd class="col-sm-8">Dr. @(Model.Doctor?.User?.FullName ?? "Selected Doctor")</dd>

                        <dt class="col-sm-4">Date:</dt>
                        <dd class="col-sm-8">@Model.AppointmentDateTime.ToString("D")</dd>

                        <dt class="col-sm-4">Time:</dt>
                        <dd class="col-sm-8">@Model.AppointmentDateTime.ToString("t")</dd>
                    </dl>

                    <form asp-action="ConfirmBooking" method="post">
                        <input type="hidden" name="AppointmentId" value="@Model.Id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">Finalize Booking</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>