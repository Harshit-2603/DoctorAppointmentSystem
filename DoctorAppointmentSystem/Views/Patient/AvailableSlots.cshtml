@model List<AppointmentSystem.Models.Models.Appointment>
@{
    ViewData["Title"] = "Pick a Slot";
    var date = ViewBag.SelectedDate as DateTime? ?? DateTime.Today;
}

<h2>Available slots — @date.ToString("D")</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<p><a asp-action="Index" class="btn btn-secondary">← Back to doctors</a></p>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No open slots for this date. Try another day, or ask the admin to generate slots for this doctor.
    </div>
}
else
{
    <div class="row">
        @foreach (var slot in Model)
        {
            <div class="col-md-3 mb-2">
                <form asp-action="Book" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="appointmentId" value="@slot.Id" />
                    <button type="submit" class="btn btn-outline-success w-100">
                        @slot.AppointmentDateTime.ToString("t")
                    </button>
                </form>
            </div>
        }
    </div>
}
